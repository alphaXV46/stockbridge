<Window x:Class="StockBridge_XAML.ConnectMobileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StockBridge Sync" Height="580" Width="400" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F4F7FA">
 
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
 
        <Border Grid.Row="0" Background="#1E293B">
            <StackPanel Margin="20">
                <TextBlock Text="STOCKBRIDGE" FontSize="14" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Center"/>
                <TextBlock Text="INTEGRASI MOBILE" FontSize="20" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
 
        <Grid Grid.Row="1" Margin="25">
            <Border Background="White" CornerRadius="15" BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel Margin="20">
                    <Border BorderBrush="#F1F5F9" BorderThickness="2" CornerRadius="10" Background="#F8FAFC">
                        <Image x:Name="imgQRCode" Width="180" Height="180" Margin="10" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <TextBlock x:Name="lblIPAddress" Text="Mencari Server..." FontSize="13" FontWeight="Bold" Foreground="#1E40AF" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    
                    <TextBlock Text="Ganti dengan URL Ngrok/HTTPS (Opsional):" FontSize="11" Foreground="#64748B" Margin="0,15,0,5" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtCustomURL" Grid.Column="0" Height="36" Style="{StaticResource ModernInput}" VerticalContentAlignment="Center" Margin="0,0,10,0" Padding="8,0"/>
                        <Button x:Name="btnGenerateCustom" Grid.Column="1" Content="Update QR" Height="36" Padding="15,0" Style="{StaticResource PrimaryButton}" Click="BtnGenerateCustom_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
 
        <Button Grid.Row="2" x:Name="BtnClose" Content="TUTUP" Style="{StaticResource SecondaryButton}" Margin="25,0,25,25" Height="40" Click="BtnClose_Click"/>
    </Grid>
</Window>