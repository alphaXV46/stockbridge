<Page x:Class="StockBridge_XAML.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Inventory Management"
      d:DesignHeight="750" d:DesignWidth="1100"
      Background="#F8FAFC">

    <Page.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Opacity="0.08" Color="{StaticResource ShadowColor}" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Inventory Repository" FontSize="26" FontWeight="Black" Foreground="{StaticResource DeepNavyBrush}"/>
                <TextBlock Text="Centralized supplier asset management system" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="btnAddProduct" Grid.Column="1" Content="+ Add New SKU" Style="{StaticResource PrimaryButton}" Click="BtnAddProduct_Click" Width="160"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="0,0,0,20" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
            <Grid Margin="15">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#F1F5F9" CornerRadius="8" Width="300">
                        <Grid Margin="10,5">
                            <TextBlock x:Name="Placeholder" Text="🔍 Search products..." Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" TextChanged="TxtSearch_TextChanged"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnUpdateStock" Content="⚙ Adjust Stock" Click="BtnUpdateStock_Click" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="btnPrintQR" Content="⎙ QR Label" Click="BtnPrintQR_Click" Style="{StaticResource SecondaryButton}" Width="120" Height="36"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource StatCardStyle}">
            <DataGrid x:Name="dgProducts" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="60"
                      Background="Transparent"
                      BorderThickness="0">
                
                <DataGrid.Columns>
                    <!-- Sequential Number Column -->
                    <DataGridTextColumn Header="NO" Binding="{Binding No}" Width="60">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="15,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Separate Product ID Column -->
                    <DataGridTextColumn Header="PRODUCT ID" Binding="{Binding id}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="15,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Separate Product Name Column -->
                    <DataGridTemplateColumn Header="PRODUCT NAME" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Border Width="35" Height="35" Background="{StaticResource BrandBlueLightBrush}" CornerRadius="8">
                                        <TextBlock Text="📦" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                    </Border>
                                    <TextBlock Text="{Binding product_name}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Right aligned price -->
                    <DataGridTextColumn Header="PRICE" Binding="{Binding price, StringFormat='Rp \{0:N0\}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,25,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Right aligned numeric quantities -->
                    <DataGridTemplateColumn Header="STOCK" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SuccessLightBrush}" CornerRadius="12" Padding="12,5" HorizontalAlignment="Right" Margin="0,0,25,0">
                                    <TextBlock Text="{Binding base_stock}" Foreground="{StaticResource SuccessTextBrush}" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Right aligned date -->
                    <DataGridTextColumn Header="MODIFIED" Binding="{Binding created_at, StringFormat=\{0:dd MMM yyyy\}}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,25,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Left aligned textual notes -->
                    <DataGridTextColumn Header="NOTES" Binding="{Binding description}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="15,0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>