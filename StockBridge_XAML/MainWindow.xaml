<Window x:Class="StockBridge_XAML.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StockBridge | Secure Login" 
        Height="650" Width="450" 
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="ModernInput" TargetType="Control">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Margin" Value="0,8,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Control">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderBrush" Value="#FEE2E2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="btnBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="btnBorder" Property="Background" Value="#FEF2F2"/>
                                <Setter TargetName="btnBorder" Property="BorderBrush" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseControlStyle" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <!-- Custom Window Controls in Top-Right -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
            <Button x:Name="btnMinimize" Content="─" Style="{StaticResource WindowControlStyle}" Click="BtnMinimize_Click"/>
            <Button x:Name="btnToggleFullscreen" Content="▢" Style="{StaticResource WindowControlStyle}" Click="BtnToggleFullscreen_Click"/>
            <Button x:Name="btnClose" Content="✕" Style="{StaticResource WindowCloseControlStyle}" Click="BtnClose_Click"/>
        </StackPanel>

        <!-- Centered Login Card -->
        <Border Width="420" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="24">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="2" Color="#0F172A" Opacity="0.15"/>
            </Border.Effect>

            <Grid Margin="40">
                <StackPanel VerticalAlignment="Center">

                    <StackPanel Margin="0,0,0,30" HorizontalAlignment="Center">
                        <Border Width="60" Height="60" Background="#3B82F6" CornerRadius="15" Margin="0,0,0,15">
                            <TextBlock Text="SB" Foreground="White" FontWeight="Black" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="STOCKBRIDGE" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Foreground="#0F172A"/>
                        <TextBlock Text="Supplier Management System" Foreground="#64748B" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#475569" FontSize="13"/>
                    <TextBox x:Name="txtUser" Style="{StaticResource ModernInput}"/>

                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#475569" FontSize="13"/>
                    <Grid>
                        <PasswordBox x:Name="txtPass" Style="{StaticResource ModernInput}"/>
                        <TextBox x:Name="txtPassUnmask" Style="{StaticResource ModernInput}" Visibility="Collapsed"/>
                        <ToggleButton x:Name="btnTogglePass" Content="👁" HorizontalAlignment="Right" VerticalAlignment="Center" 
                                      Margin="0,0,15,8" Width="30" Height="30" Cursor="Hand" Background="Transparent" BorderThickness="0"
                                      Click="BtnTogglePass_Click"/>
                    </Grid>

                    <Button Content="SIGN IN" Style="{StaticResource LoginButton}" Click="BtnLogin_Click" Margin="0,10,0,0"/>
                    <Button Content="KELUAR APLIKASI" Style="{StaticResource SecondaryButton}" Click="BtnClose_Click" Margin="0,10,0,0"/>

                    <TextBlock Text="© 2026 StockBridge Professional" Foreground="#94A3B8" FontSize="10" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>