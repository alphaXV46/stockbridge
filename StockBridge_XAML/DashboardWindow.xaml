<Window x:Class="StockBridge_XAML.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StockBridge | Enterprise Supplier Portal" Height="850" Width="1400" 
        WindowStartupLocation="CenterScreen" Background="#F1F5F9"
        FontFamily="Segoe UI Semibold"
        WindowStyle="None" AllowsTransparency="True"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="12,2,12,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="30,0,0,0">
                    <Border Width="50" Height="50" Background="#3B82F6" CornerRadius="12" HorizontalAlignment="Left">
                        <TextBlock Text="SB" Foreground="White" FontSize="22" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="STOCKBRIDGE" Foreground="White" FontSize="20" FontWeight="Black" Margin="0,12,0,0"/>
                    <TextBlock Text="MANAGEMENT SYSTEM V.2" Foreground="#475569" FontSize="11" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <TextBlock Text="CORE MODULES" Foreground="#334155" FontSize="11" FontWeight="Bold" Margin="25,20,0,10"/>
                    <Button x:Name="btnMenuInventory" Content="📦  Inventory Dashboard" Style="{StaticResource NavButtonStyle}" Click="MenuInventory_Click"/>
                    <Button x:Name="btnMenuLogs" Content="📊  Analytics &amp; Logs" Style="{StaticResource NavButtonStyle}" Click="MenuLogs_Click"/>
                    <Button x:Name="btnMenuRequest" Content="📨  Supply Requests" Style="{StaticResource NavButtonStyle}" Click="MenuRequest_Click"/>
                    <Button x:Name="btnMenuUsers" Content="👥  Team Management" Style="{StaticResource NavButtonStyle}" Click="MenuUsers_Click"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#1E293B" CornerRadius="15" Margin="15,0,15,20" Padding="15">
                    <StackPanel>
                        <TextBlock x:Name="lblRoleDisplay" Text="ADMINISTRATOR" Foreground="#3B82F6" FontSize="10" FontWeight="Black" Margin="0,0,0,5"/>
                        <Button x:Name="btnLogout" Content="Sign Out" Style="{StaticResource DangerButton}" Height="35" Click="BtnLogout_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="30,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="lblWelcome" Text="Dashboard" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="Enterprise System" FontSize="12" Foreground="#94A3B8"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="btnConnectMobile" Content="📱 Sync Mobile" Style="{StaticResource SecondaryButton}" Height="36" Padding="15,0" Click="BtnConnectMobile_Click" Margin="0,0,15,0"/>
                        <Button x:Name="btnMinimize" Content="─" Style="{StaticResource WindowControlStyle}" Click="BtnMinimize_Click"/>
                        <Button x:Name="btnToggleFullscreen" Content="▢" Style="{StaticResource WindowControlStyle}" Click="BtnToggleFullscreen_Click"/>
                        <Button x:Name="btnClose" Content="✕" Style="{StaticResource WindowCloseControlStyle}" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="30">
                <Border x:Name="DefaultContent" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Welcome to StockBridge" FontSize="24" FontWeight="Black" Foreground="#0F172A"/>
                    </StackPanel>
                </Border>
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
            </Grid>
        </Grid>
    </Grid>
</Window>