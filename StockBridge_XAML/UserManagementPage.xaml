<Page x:Class="StockBridge_XAML.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Access Management"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="ModernFieldStyle" TargetType="Control">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="UserGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="60"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8FAFC"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="Padding" Value="20,15"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="35">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,35">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Team Access Control" FontSize="30" FontWeight="Black" Foreground="#0F172A"/>
                <TextBlock Text="Configure user roles, permissions, and security settings for StockBridge." Foreground="#64748B" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Background="#DBEAFE" CornerRadius="8" Padding="12,6" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#1E40AF" Margin="0,0,8,0"/>
                    <TextBlock Text="AUTHORIZED ACCESS" FontSize="10" FontWeight="Black" Foreground="#1E40AF"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,30" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="4" Color="#000000" Opacity="0.04"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="ADD NEW TEAM MEMBER" FontSize="12" FontWeight="Black" Foreground="#1E40AF" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabelStyle}"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBox x:Name="txtNewUser" Style="{StaticResource ModernFieldStyle}" BorderThickness="0" Padding="12,0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="PASSWORD" Style="{StaticResource InputLabelStyle}"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                            <TextBox x:Name="txtNewPass" Style="{StaticResource ModernFieldStyle}" BorderThickness="0" Padding="12,0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="ACCESS LEVEL" Style="{StaticResource InputLabelStyle}"/>
                        <Border CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1">
                            <ComboBox x:Name="cbNewRole" Style="{StaticResource ModernFieldStyle}" BorderThickness="0">
                                <ComboBoxItem Content="Staff (Warehouse)" IsSelected="True"/>
                                <ComboBoxItem Content="Manager (Approval)"/>
                                <ComboBoxItem Content="Admin (Full Access)"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Add Member" Click="BtnSaveUser_Click" 
                            Background="#0F172A" Foreground="White" Width="140" Height="42" 
                            FontWeight="Bold" FontSize="13" Margin="0,19,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="4" Color="#000000" Opacity="0.04"/>
            </Border.Effect>
            <DataGrid x:Name="dgUsers" 
                      Style="{StaticResource UserGridStyle}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="UID" Binding="{Binding id}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="25,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="NAME &amp; IDENTITY" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="20,0">
                                    <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16">
                                        <TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                    </Border>
                                    <TextBlock Text="{Binding username}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1E293B" FontSize="14" Margin="12,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ROLE STATUS" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="RoleBadge" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left" Margin="20,0">
                                    <TextBlock x:Name="RoleText" Text="{Binding role}" FontSize="10" FontWeight="Black"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding role}" Value="Admin">
                                        <Setter TargetName="RoleBadge" Property="Background" Value="#FEE2E2"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="#991B1B"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding role}" Value="Manager">
                                        <Setter TargetName="RoleBadge" Property="Background" Value="#DBEAFE"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="#1E40AF"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>