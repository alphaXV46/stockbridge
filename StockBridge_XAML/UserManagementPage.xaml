<Page x:Class="StockBridge_XAML.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="User Access Management"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Page.Resources>

    <Grid Margin="35">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,35">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Team Access Control" FontSize="30" FontWeight="Black" Foreground="{StaticResource DeepNavyBrush}"/>
                <TextBlock Text="Configure user roles, permissions, and security settings for StockBridge." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,4,0,0"/>
            </StackPanel>

            <Border Background="{StaticResource BrandBlueLightBrush}" CornerRadius="8" Padding="12,6" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource BrandBlueBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="AUTHORIZED ACCESS" FontSize="10" FontWeight="Black" Foreground="{StaticResource DeepNavyBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="25" Margin="0,0,0,30" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="4" Color="{StaticResource ShadowColor}" Opacity="0.04"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="ADD NEW TEAM MEMBER" FontSize="12" FontWeight="Black" Foreground="{StaticResource BrandBlueBrush}" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="USERNAME" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox x:Name="txtNewUser"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="PASSWORD" Style="{StaticResource InputLabelStyle}"/>
                        <TextBox x:Name="txtNewPass"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Text="ACCESS LEVEL" Style="{StaticResource InputLabelStyle}"/>
                        <ComboBox x:Name="cbNewRole">
                            <ComboBoxItem Content="Staff (Warehouse)" IsSelected="True"/>
                            <ComboBoxItem Content="Manager (Approval)"/>
                            <ComboBoxItem Content="Admin (Full Access)"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="3" Content="Add Member" Style="{StaticResource PrimaryButton}" Click="BtnSaveUser_Click" 
                            Width="140" Height="40" Margin="0,19,0,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="16" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="4" Color="{StaticResource ShadowColor}" Opacity="0.04"/>
            </Border.Effect>
            <DataGrid x:Name="dgUsers" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      Margin="15">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="UID" Binding="{Binding id}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="20,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="NAME &amp; IDENTITY" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="15,0">
                                    <Border Width="32" Height="32" Background="#F1F5F9" CornerRadius="16">
                                        <TextBlock Text="👤" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                                    </Border>
                                    <TextBlock Text="{Binding username}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="12,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Center-aligned user role badge -->
                    <DataGridTemplateColumn Header="ROLE STATUS" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="RoleBadge" CornerRadius="8" Padding="12,5" HorizontalAlignment="Center" Margin="15,0" Background="#F1F5F9">
                                    <TextBlock x:Name="RoleText" Text="{Binding role}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding role}" Value="Admin">
                                        <Setter TargetName="RoleBadge" Property="Background" Value="{StaticResource DangerLightBrush}"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="{StaticResource DangerTextBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding role}" Value="Manager">
                                        <Setter TargetName="RoleBadge" Property="Background" Value="{StaticResource BrandBlueLightBrush}"/>
                                        <Setter TargetName="RoleText" Property="Foreground" Value="{StaticResource BrandBlueBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>