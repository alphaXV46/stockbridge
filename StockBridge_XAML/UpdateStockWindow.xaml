<Window x:Class="StockBridge_XAML.UpdateStockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inventory Adjustment" Height="520" Width="420" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F1F5F9">

    <Window.Resources>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White" CornerRadius="16" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="{StaticResource ShadowColor}" Opacity="0.08"/>
            </Border.Effect>

            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <Border Background="{StaticResource BrandBlueLightBrush}" CornerRadius="6" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock Text="STOCK ADJUSTMENT" FontSize="10" FontWeight="Black" Foreground="{StaticResource BrandBlueBrush}" Margin="8,4"/>
                    </Border>
                    <TextBlock x:Name="lblProductName" Text="PRODUCT NAME" FontSize="18" FontWeight="Black" Foreground="{StaticResource DeepNavyBrush}" TextWrapping="Wrap"/>
                    <Rectangle Height="1" Fill="#F1F5F9" Margin="0,15,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <TextBlock Text="TIPE TRANSAKSI" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="cbTransactionType" Margin="0,0,0,18">
                        <ComboBoxItem Content="Barang Masuk" IsSelected="True"/>
                        <ComboBoxItem Content="Barang Keluar"/>
                    </ComboBox>

                    <TextBlock Text="SATUAN" Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox x:Name="cbUnitType" Margin="0,0,0,18">
                        <ComboBoxItem x:Name="itemUnit" Content="Loading..."/>
                        <ComboBoxItem x:Name="itemPack" Content="Loading..."/>
                    </ComboBox>

                    <TextBlock Text="JUMLAH QUANTITY" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="txtQuantity" Text="1" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrandBlueBrush}" 
                             Padding="10,0"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button Content="SIMPAN PERUBAHAN" Style="{StaticResource PrimaryButton}" Click="BtnProcess_Click" Height="45"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>