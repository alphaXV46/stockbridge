<Page x:Class="StockBridge_XAML.RequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Supply Request | StockBridge"
      Background="Transparent">

    <Page.Resources>
        <!-- Red outline decline button -->
        <Style x:Key="DeclineButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,25">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Supply Management" FontSize="12" FontWeight="Bold" Foreground="{StaticResource BrandBlueBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="Inventory Requests" FontSize="26" FontWeight="Black" Foreground="{StaticResource DeepNavyBrush}"/>
                <TextBlock Text="Review and process stock movement requests across branches." Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="btnNewRequest" Content="+ New Request" 
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Style="{StaticResource PrimaryButton}" Click="BtnNewRequest_Click" Height="42" Padding="20,0"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="15" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="{StaticResource ShadowColor}" Opacity="0.04"/>
            </Border.Effect>

            <DataGrid x:Name="dgRequests" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      BorderThickness="0"
                      Background="Transparent"
                      CanUserAddRows="False"
                      Margin="15" HorizontalAlignment="Stretch">

                <DataGrid.Columns>
                    <!-- Left-aligned Reference Number (Consolas font) -->
                    <DataGridTextColumn Header="REFERENCE" Binding="{Binding id}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="15,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontFamily" Value="Consolas"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Left-aligned textual column -->
                    <DataGridTextColumn Header="ITEM NAME" Binding="{Binding product_name}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="15,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Right-aligned numeric quantity -->
                    <DataGridTextColumn Header="QUANTITY" Binding="{Binding qty_requested}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,25,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="TextAlignment" Value="Right"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Center-aligned status badges -->
                    <DataGridTemplateColumn Header="STATUS" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border x:Name="StatusBadge" CornerRadius="8" Padding="12,5" HorizontalAlignment="Center" Margin="10,0">
                                    <TextBlock x:Name="StatusText" Text="{Binding status}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding status}" Value="Pending">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource WarningTextBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding status}" Value="Approved">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource SuccessTextBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding status}" Value="Rejected">
                                        <Setter TargetName="StatusBadge" Property="Background" Value="{StaticResource DangerLightBrush}"/>
                                        <Setter TargetName="StatusText" Property="Foreground" Value="{StaticResource DangerTextBrush}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Modern bottom action bar for Manager reviews -->
        <Border x:Name="panelManagerAction" Grid.Row="2" Background="{StaticResource PrimaryBackgroundBrush}" BorderBrush="{StaticResource BorderBrushBase}" BorderThickness="1" CornerRadius="12" Margin="0,20,0,0" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="10" Background="{StaticResource BrandBlueBrush}" CornerRadius="5" Margin="0,0,12,0"/>
                    <TextBlock Text="Manager Review Mode" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Decline Request" Click="BtnReject_Click" Style="{StaticResource DeclineButtonStyle}" Width="140" Height="38" Margin="0,0,12,0"/>
                    <Button Content="Approve Supply" Click="BtnApprove_Click" Style="{StaticResource SuccessButton}" Width="140" Height="38">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Color="#10B981" Opacity="0.15"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>